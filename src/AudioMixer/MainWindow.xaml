<Window x:Class="AudioMixer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AudioMixer.ViewModels"
        xmlns:views="clr-namespace:AudioMixer.Views"
        Title="AudioMixer" Height="720" Width="1040" MinHeight="520" MinWidth="820"
        Background="{StaticResource BgBrush}"
        Icon="pack://application:,,,/Assets/app.ico"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:RoutesViewModel}">
            <views:RoutesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:VirtualMicViewModel}">
            <views:VirtualMicView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PhoneViewModel}">
            <views:PhoneView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource PanelBrush}">
            <DockPanel Margin="12,16">
                <StackPanel DockPanel.Dock="Top">
                    <StackPanel Orientation="Horizontal" Margin="14,0,0,20">
                        <TextBlock Text="◉" FontSize="20" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="AudioMixer" FontSize="17" FontWeight="Bold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <RadioButton Style="{StaticResource NavButton}" Content="Routes" IsChecked="True"
                                 Command="{Binding NavigateCommand}" CommandParameter="Routes"/>
                    <RadioButton Style="{StaticResource NavButton}" Content="Virtual Mic"
                                 Command="{Binding NavigateCommand}" CommandParameter="VirtualMic"/>
                    <RadioButton Style="{StaticResource NavButton}" Content="Phone"
                                 Command="{Binding NavigateCommand}" CommandParameter="Phone"/>
                    <RadioButton Style="{StaticResource NavButton}" Content="Settings"
                                 Command="{Binding NavigateCommand}" CommandParameter="Settings"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Bottom" VerticalAlignment="Bottom" Style="{StaticResource Sub}" Margin="14,0,0,4"
                           Text="Route any audio, anywhere."/>
            </DockPanel>
        </Border>

        <!-- Content -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentPage}" Margin="24,20,24,12"/>
    </Grid>
</Window>
