<UserControl x:Class="AudioMixer.Views.RoutesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AudioMixer.Views">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <views:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
    </UserControl.Resources>

    <DockPanel>
        <!-- Header -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Routes" Style="{StaticResource H1}"/>
                <TextBlock Style="{StaticResource Sub}" Margin="0,4,0,0"
                           Text="Send any source — an app, a device, your phone — to one or more outputs at once."/>
            </StackPanel>
            <Button Style="{StaticResource PrimaryButton}" Content="＋  Add route" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Command="{Binding AddRouteCommand}"/>
        </Grid>

        <!-- Empty state -->
        <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Padding="32"
                Visibility="{Binding HasNoRoutes, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="No routes yet" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock Style="{StaticResource Sub}" Margin="0,6,0,0" HorizontalAlignment="Center"
                           Text="Add a route, pick a source (e.g. “What's playing on Speakers” or a specific game), then toggle the outputs that should play it."/>
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Routes}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Source → outputs -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="280"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ComboBox Grid.Column="0" Tag="Choose a source…"
                                              ItemsSource="{Binding DataContext.SourceOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              SelectedItem="{Binding SelectedSource}"
                                              DropDownOpened="SourceCombo_DropDownOpened">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="{StaticResource AccentDimBrush}" CornerRadius="4" Padding="5,1" Margin="0,0,8,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Badge}" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" MaxWidth="360" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <TextBlock Grid.Column="1" Text="→" FontSize="18" Foreground="{StaticResource SubTextBrush}" Margin="14,0" VerticalAlignment="Center"/>

                                    <ItemsControl Grid.Column="2" ItemsSource="{Binding Outputs}" VerticalAlignment="Center">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <ToggleButton Style="{StaticResource Chip}" Content="{Binding Name}" IsChecked="{Binding IsSelected}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Button Grid.Column="3" Style="{StaticResource IconButton}" Content="✕" ToolTip="Remove route"
                                            VerticalAlignment="Top" Command="{Binding RemoveCommand}"/>
                                </Grid>

                                <!-- Volume / mute / status -->
                                <Grid Grid.Row="1" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Vol" Style="{StaticResource Sub}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding VolumePercent}" VerticalAlignment="Center"/>
                                    <ToggleButton Grid.Column="2" Style="{StaticResource Chip}" Margin="16,0,0,0" Padding="10,4"
                                                  Content="Mute" IsChecked="{Binding IsMuted}"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Status}" Style="{StaticResource Sub}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- VU -->
                                <ProgressBar Grid.Row="2" Style="{StaticResource VuMeter}" Value="{Binding Peak, Mode=OneWay}" Margin="0,12,0,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
