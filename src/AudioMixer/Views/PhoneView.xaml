<UserControl x:Class="AudioMixer.Views.PhoneView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AudioMixer.Views">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <views:BoolToStringConverter x:Key="BoolToString"/>
        <views:InverseBoolConverter x:Key="InvBool"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Phone" Style="{StaticResource H1}"/>
            <TextBlock Style="{StaticResource Sub}" Margin="0,4,0,16"
                       Text="Use your phone as an audio source — over the USB cable or over Bluetooth."/>

            <!-- USB -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="USB cable" FontWeight="SemiBold" FontSize="15"/>
                    <TextBlock Text="{Binding UsbStatusTitle}" Margin="0,10,0,2" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="{Binding UsbStatusDetail}" Style="{StaticResource Sub}"/>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Style="{StaticResource PrimaryButton}" Content="Start streaming"
                                Command="{Binding ConnectUsbCommand}"
                                Visibility="{Binding CanConnectUsb, Converter={StaticResource BoolToVis}}"/>
                        <Button Style="{StaticResource GhostButton}" Content="Stop"
                                Command="{Binding DisconnectUsbCommand}"
                                Visibility="{Binding IsUsbStreaming, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <Expander Margin="0,14,0,0" Foreground="{StaticResource SubTextBrush}"
                              Visibility="{Binding ShowSetupHelp, Converter={StaticResource BoolToVis}}">
                        <Expander.Header>
                            <TextBlock Text="One-time phone setup (USB debugging)" Style="{StaticResource Sub}"/>
                        </Expander.Header>
                        <StackPanel Margin="16,8,0,0">
                            <TextBlock Style="{StaticResource Sub}" Text="1.  On the phone: Settings → About phone → tap “Build number” 7 times (unlocks Developer options)."/>
                            <TextBlock Style="{StaticResource Sub}" Margin="0,4,0,0" Text="2.  Settings → System → Developer options → turn on “USB debugging”."/>
                            <TextBlock Style="{StaticResource Sub}" Margin="0,4,0,0" Text="3.  Plug the cable in and accept “Allow USB debugging?” on the phone (tick Always allow)."/>
                            <TextBlock Style="{StaticResource Sub}" Margin="0,4,0,0" Text="4.  Done — from now on it's plug and play. Requires Android 11 or newer."/>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Border>

            <!-- Bluetooth -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <Grid>
                        <TextBlock Text="Bluetooth (PC acts as a speaker)" FontWeight="SemiBold" FontSize="15"/>
                        <Button Style="{StaticResource GhostButton}" Content="Refresh" Padding="10,4" HorizontalAlignment="Right"
                                Command="{Binding RefreshBluetoothCommand}"/>
                    </Grid>
                    <TextBlock Text="{Binding BluetoothStatus}" Style="{StaticResource Sub}" Margin="0,10,0,10"/>

                    <ItemsControl ItemsSource="{Binding BluetoothPhones}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Style="{StaticResource GhostButton}" MinWidth="110"
                                            Content="{Binding IsConnected, Converter={StaticResource BoolToString}, ConverterParameter=Disconnect|Connect}"
                                            Command="{Binding ToggleCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
