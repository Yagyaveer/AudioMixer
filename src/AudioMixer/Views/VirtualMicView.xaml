<UserControl x:Class="AudioMixer.Views.VirtualMicView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AudioMixer.Views">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <views:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Grid Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Virtual Mic" Style="{StaticResource H1}"/>
                    <TextBlock Style="{StaticResource Sub}" Margin="0,4,0,0"
                               Text="Mix your real mic with game/browser/phone audio. Friends hear everything when they listen to “CABLE Output” as your microphone."/>
                </StackPanel>
                <ToggleButton Style="{StaticResource Switch}" HorizontalAlignment="Right" VerticalAlignment="Top"
                              IsChecked="{Binding IsEnabled}"/>
            </Grid>

            <!-- VB-Cable missing warning -->
            <Border Style="{StaticResource Card}" BorderBrush="#665500" Background="#221A00" Margin="0,0,0,12"
                    Visibility="{Binding CableInstalled, Converter={StaticResource InvBoolToVis}}">
                <StackPanel>
                    <TextBlock Text="VB-Cable is not installed" FontWeight="SemiBold"/>
                    <TextBlock Style="{StaticResource Sub}" Margin="0,4,0,10"
                               Text="The virtual mic needs the free VB-Audio Virtual Cable driver (one-time install, then reboot). After installing, this page unlocks automatically."/>
                    <Button Style="{StaticResource PrimaryButton}" Content="Get VB-Cable" HorizontalAlignment="Left"
                            Command="{Binding DataContext.SettingsVm.InstallCableCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                </StackPanel>
            </Border>

            <!-- Mic -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Your microphone" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="240"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" ItemsSource="{Binding Mics}" SelectedItem="{Binding SelectedMic}" Tag="Pick your mic…">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" MaxWidth="290" TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Grid.Column="1" Text="Gain" Style="{StaticResource Sub}" VerticalAlignment="Center" Margin="16,0,10,0"/>
                        <Slider Grid.Column="2" Minimum="0" Maximum="150" Value="{Binding MicGainPercent}" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Mixed-in sources -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Also send to friends" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Style="{StaticResource Sub}" Margin="0,0,0,12"
                               Text="Anything added here gets mixed into your mic signal — Chrome, a game, your phone…"/>

                    <ItemsControl ItemsSource="{Binding ExtraSources}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="320"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="240"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" Text="Gain" Style="{StaticResource Sub}" VerticalAlignment="Center" Margin="16,0,10,0"/>
                                    <Slider Grid.Column="2" Minimum="0" Maximum="150" Value="{Binding GainPercent}" VerticalAlignment="Center"/>
                                    <Button Grid.Column="3" Style="{StaticResource IconButton}" Content="✕" HorizontalAlignment="Right"
                                            Command="{Binding RemoveCommand}" ToolTip="Remove from mix"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" ItemsSource="{Binding AddableSources}" SelectedItem="{Binding SelectedAddable}"
                                  Tag="Pick something to add…" DropDownOpened="AddableCombo_DropDownOpened">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="{StaticResource AccentDimBrush}" CornerRadius="4" Padding="5,1" Margin="0,0,8,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Badge}" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                                        </Border>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" MaxWidth="360" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Grid.Column="1" Style="{StaticResource GhostButton}" Content="Add to mix" Margin="10,0,0,0"
                                Command="{Binding AddSourceCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Status + meter -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="{Binding Status}" Style="{StaticResource Sub}" Margin="0,0,0,10"/>
                    <ProgressBar Style="{StaticResource VuMeter}" Value="{Binding Peak, Mode=OneWay}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
